.success .check{width:72px;height:72px;border-radius:50%;background:var(--volt);display:grid;place-items:center;margin:0 auto 16px}
.wa-phone{background:#0b141a;border-radius:22px;padding:10px;max-width:320px;margin:18px auto 0;border:6px solid #1f2c34}
.wa-top{background:#1f2c34;border-radius:14px 14px 0 0;padding:9px 12px;display:flex;align-items:center;gap:9px;color:#e9edef}
