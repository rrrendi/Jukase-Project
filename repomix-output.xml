                    'date' => now()->subDays($data['days_ago'])->toDateString(),
                ]);

                // Stok awal 0 -> setelah applyStockIn(), avg_cost = harga modal & stock = qty masuk.
                $product->applyStockIn($data['stock'], $data['cost']);
            }
        }
    }
}
