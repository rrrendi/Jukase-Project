.stat.dark .lbl{color:#8a8678}
.stat.dark .val{color:var(--volt)}

.panel{background:#FBF9F3;border:1px solid var(--line-strong);border-radius:var(--r);overflow:hidden;margin-bottom:24px}
.panel-head{padding:16px 20px;border-bottom:1px solid var(--line-strong);display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
.panel-head h3{font-size:17px;font-weight:800}
.panel-head .sub{font-size:12.5px;color:var(--muted)}
.panel-body{padding:20px}

.jk table{width:100%;border-collapse:collapse}
.jk th{font-family:var(--mono);font-size:10.5px;letter-spacing:.06em;text-transform:uppercase;color:var(--muted);text-align:left;padding:12px 20px;border-bottom:1px solid var(--line-strong);font-weight:700}
.jk td{padding:13px 20px;border-bottom:1px solid var(--line);font-size:13.5px;vertical-align:middle}
.jk tr:last-child td{border-bottom:none}
.jk tbody tr{transition:.12s}
.jk tbody tr:hover{background:#00000004}
.cellname{font-weight:700}
.cellsub{font-size:12px;color:var(--muted)}
.col-item{max-width:220px}
.jk-row-toggle{display:none} /* cuma dipakai di tampilan kartu mobile, lihat @media(max-width:760px) */
.thumb-img{width:40px;height:40px;border-radius:9px;object-fit:cover;vertical-align:middle;margin-right:9px;flex-shrink:0}
.mini-thumb{width:40px;height:40px;border-radius:9px;display:inline-grid;place-items:center;font-size:18px;vertical-align:middle;margin-right:9px;flex-shrink:0}
.table-flex{display:flex;align-items:center}

.chart-wrap{padding:8px 20px 20px}
.bars{display:flex;align-items:flex-end;gap:14px;height:170px;padding-top:10px}
.bar-col{flex:1;display:flex;flex-direction:column;align-items:center;gap:8px;height:100%;justify-content:flex-end}
.bar{width:100%;max-width:34px;border-radius:7px 7px 3px 3px;background:var(--paper-3);transition:height .6s cubic-bezier(.4,0,.1,1);position:relative;min-height:3px}
.bar.hot{background:var(--ink)}
.bar.top{background:var(--volt)}
.bar-col .d{font-family:var(--mono);font-size:10px;color:var(--muted)}
.bar::after{content:attr(data-v);position:absolute;top:-22px;left:50%;transform:translateX(-50%);
  background:var(--ink);color:var(--paper);font-family:var(--mono);font-size:10px;padding:3px 7px;border-radius:6px;white-space:nowrap;opacity:0;transition:.15s;pointer-events:none}
.bar:hover::after{opacity:1}

.split{display:grid;grid-template-columns:1.55fr 1fr;gap:18px}
.alert-row{display:flex;align-items:center;gap:12px;padding:12px 20px;border-bottom:1px solid var(--line)}
.alert-row:last-child{border-bottom:none}
.alert-row .nm{font-weight:700;font-size:13.5px}
.alert-row .left{font-family:var(--mono);font-size:12px;font-weight:700;margin-left:auto}

/* segmented tabs */
.seg{display:inline-flex;background:var(--paper-2);border-radius:12px;padding:4px;gap:3px;flex-wrap:wrap}
.seg a,.seg button{padding:8px 15px;border-radius:9px;font-size:13px;font-weight:700;color:var(--muted);transition:.14s;display:inline-block}
.seg a.active,.seg button.active{background:#FBF9F3;color:var(--ink);box-shadow:0 1px 4px #0000001a}

.proof{width:46px;height:46px;border-radius:10px;object-fit:cover;display:block;border:1px solid var(--line-strong);transition:.15s}
.proof:hover{transform:scale(1.05);border-color:var(--ink)}

.cfg-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px}
.cfg-card{background:#FBF9F3;border:1px solid var(--line-strong);border-radius:var(--r);padding:22px;margin-bottom:0}
.cfg-card h4{font-size:16px;font-weight:800;margin-bottom:4px}
.cfg-card .desc{font-size:12.5px;color:var(--muted);margin-bottom:16px}

.note{font-family:var(--mono);font-size:11px;color:var(--muted);letter-spacing:.02em;line-height:1.7}

.form-actions{display:flex;gap:10px;justify-content:flex-end;margin-top:18px}
