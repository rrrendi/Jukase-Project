/* footer */
.shop-footer{background:var(--ink);color:#9a978c;padding:36px 24px;margin-top:50px}
.shop-footer .inner{max-width:1180px;margin:0 auto;display:flex;justify-content:space-between;flex-wrap:wrap;gap:14px;font-size:12.5px;align-items:center}
.shop-footer .brand{color:var(--paper);font-family:var(--disp);font-weight:800;font-size:17px;display:flex;align-items:center;gap:8px}

/* empty state */
