}

/* Toast Notifikasi */
.jk-toast-container{position:fixed;right:20px;z-index:150;display:flex;flex-direction:column;gap:10px;max-width:340px}
.jk-toast{display:flex;align-items:center;gap:10px;border-radius:12px;padding:13px 16px;font-family:var(--body);font-size:13.5px;font-weight:600;box-shadow:var(--shadow);opacity:0;transform:translateX(24px);transition:all .3s ease}
.jk-toast.show{opacity:1;transform:translateX(0)}
