    {
        $categories = Category::pluck('id', 'name');
        $suppliers = Supplier::pluck('id')->values();

        $products = [
            ['brand' => 'Nike', 'name' => "Air Force 1 '07", 'category' => 'Sneakers', 'size_range' => '39-44', 'color' => 'Putih', 'price' => 1499000, 'cost' => 1180000, 'stock' => 8, 'days_ago' => 22],
