.topbar-actions{display:flex;align-items:center;gap:12px;flex-wrap:wrap}
.shop-link-btn{flex-shrink:0}
.admin-page{padding:26px 30px 60px;max-width:1280px}

.stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
.stat{background:#FBF9F3;border:1px solid var(--line-strong);border-radius:var(--r);padding:18px 20px;position:relative;overflow:hidden}
.stat .lbl{font-family:var(--mono);font-size:10.5px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
