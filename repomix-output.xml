.li .meta .p{font-family:var(--disp);font-weight:800;margin-top:4px}
.li .right{display:flex;flex-direction:column;align-items:flex-end;gap:8px;flex-shrink:0}

.qty{display:inline-flex;align-items:center;border:1.5px solid var(--line-strong);border-radius:9px;overflow:hidden}
.qty button{width:28px;height:28px;font-weight:700;font-size:15px}
.qty button:hover{background:var(--ink);color:var(--volt)}
.qty input{width:38px;height:28px;text-align:center;font-family:var(--mono);font-size:13px;font-weight:700;border:none;background:transparent}
.qty input:focus{outline:none}

.field{margin-bottom:14px}
.field label{display:block;font-size:12.5px;font-weight:700;margin-bottom:6px}
.field label .req{color:var(--coral)}
.field input,.field textarea,.field select{width:100%;padding:11px 13px;border-radius:11px;border:1.5px solid var(--line-strong);background:#FBF9F3}
.field input:focus,.field textarea:focus,.field select:focus{outline:none;border-color:var(--ink)}
.field input.invalid,.field textarea.invalid,.field select.invalid{border-color:var(--danger)}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}

.checkbox-row{display:flex;align-items:center;gap:10px;font-size:13px;font-weight:600;margin-bottom:14px}
.checkbox-row input[type=checkbox]{width:18px;height:18px;accent-color:var(--ink)}

.pay-box{background:var(--ink);color:var(--paper);border-radius:14px;padding:16px;margin:6px 0 14px}
.pay-box .row{display:flex;justify-content:space-between;align-items:center;padding:6px 0;font-size:13px}
