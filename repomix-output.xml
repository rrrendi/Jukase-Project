.qris .code{width:64px;height:64px;border-radius:8px;background:
  repeating-conic-gradient(#14130F 0% 25%, #fff 0% 50%) 50%/12px 12px;flex-shrink:0}

.upload{border:1.6px dashed var(--line-strong);border-radius:13px;padding:22px;text-align:center;color:var(--muted);transition:.15s;cursor:pointer;display:block}
.upload:hover{border-color:var(--ink);background:#00000005;color:var(--ink)}
