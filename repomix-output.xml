<file path="resources/css/jukase.css">
/* =====================================================================
   JUKASE PROJECT - Design System
   Diadaptasi dari prototipe UI (jukase-ui.html) untuk digunakan di
   seluruh halaman Blade (storefront & panel admin). File ini di-import
   dari resources/css/app.css agar diproses Vite bersama Tailwind.
   ===================================================================== */

:root{
  --ink:#14130F;
  --ink-2:#1F1D17;
  --ink-soft:#2C2A22;
  --paper:#F4F0E6;
  --paper-2:#EAE4D5;
  --paper-3:#E0D8C4;
  --volt:#CCF000;
  --volt-deep:#A8C800;
  --coral:#FF5A3C;
  --line:#1413100F;
  --line-strong:#14131022;
  --ok:#1F9D55;
  --ok-bg:#DDF3E4;
  --warn:#B7791F;
  --warn-bg:#FBEED0;
  --danger:#D63A3A;
  --danger-bg:#FBE0E0;
  --muted:#6B675C;
  --r:18px;
  --shadow:0 1px 0 #00000008, 0 18px 40px -28px #00000055;
  --disp:"Bricolage Grotesque", sans-serif;
  --body:"Hanken Grotesk", sans-serif;
  --mono:"Space Mono", monospace;
}

/* ====== BASE ====== */
.jk *{box-sizing:border-box}
.jk{
  font-family:var(--body);
  background:var(--paper);
  color:var(--ink);
  -webkit-font-smoothing:antialiased;
  line-height:1.5;
  min-height:100vh;
}
.jk h1,.jk h2,.jk h3,.jk h4{font-family:var(--disp);margin:0;line-height:1.05;letter-spacing:-.02em}
.jk button{font-family:inherit;cursor:pointer;border:none;background:none}
.jk input,.jk select,.jk textarea{font-family:inherit;font-size:14px}
.jk a{color:inherit;text-decoration:none}
.mono{font-family:var(--mono)}

/* ====== TAGS / PILLS / BADGES ====== */
.tag{font-family:var(--mono);font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;font-weight:700}
.pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:11px;font-weight:700;font-family:var(--mono);letter-spacing:.03em}
.pill.ok{background:var(--ok-bg);color:var(--ok)}
.pill.warn{background:var(--warn-bg);color:var(--warn)}
.pill.danger{background:var(--danger-bg);color:var(--danger)}
.pill.neutral{background:var(--paper-3);color:var(--muted)}
.dot{width:7px;height:7px;border-radius:50%;background:currentColor}

/* ====== BUTTONS ====== */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;font-weight:700;
  border-radius:12px;padding:12px 18px;font-size:14px;transition:transform .12s,background .18s,box-shadow .18s;letter-spacing:-.01em}
.btn:active{transform:translateY(1px)}
.btn-primary{background:var(--ink);color:var(--paper)}
.btn-primary:hover{box-shadow:0 12px 22px -12px #14131099}
.btn-volt{background:var(--volt);color:var(--ink)}
.btn-volt:hover{background:#d8ff14}
.btn-ghost{background:var(--paper-2);border:1.5px solid var(--line-strong);color:var(--ink)}
.btn-ghost:hover{background:var(--ink);color:var(--paper);border-color:var(--ink)}
.btn-danger{background:var(--danger-bg);color:var(--danger)}
.btn-danger:hover{background:#f6c6c6}
.btn-sm{padding:8px 13px;font-size:13px;border-radius:10px}
.btn-block{width:100%}
.btn[disabled]{opacity:.5;cursor:not-allowed}

/* ====== FLASH / ALERTS ====== */
.flash{padding:13px 16px;border-radius:12px;font-size:13.5px;font-weight:600;margin-bottom:18px;display:flex;align-items:center;gap:10px}
.flash.success{background:var(--ok-bg);color:var(--ok)}
.flash.error{background:var(--danger-bg);color:var(--danger)}
.error-text{color:var(--danger);font-size:12px;font-weight:600;margin-top:5px;display:block}

/* ============================================================= STOREFRONT */
.shop-header{position:sticky;top:0;z-index:60;background:#E0D8C4E6;backdrop-filter:blur(0px);border-bottom:1px solid var(--line-strong)}
.shop-header .bar{max-width:1180px;margin:0 auto;padding:16px 24px;display:flex;align-items:center;gap:28px;background:none;width:auto;min-height:0;position:static}.wordmark{font-family:var(--disp);font-weight:800;font-size:22px;letter-spacing:-.03em;display:flex;align-items:center;gap:8px}
.wordmark .sq{width:26px;height:26px;background:var(--ink);border-radius:7px;display:grid;place-items:center}
.wordmark .sq b{color:var(--volt);font-size:15px;font-family:var(--disp)}
.shop-nav{display:flex;gap:24px;margin-left:8px}
.shop-nav a{font-size:14px;font-weight:600;color:var(--muted);transition:.15s}
.shop-nav a:hover,.shop-nav a.active{color:var(--ink)}
.header-spacer{flex:1}
.icon-btn{width:42px;height:42px;border-radius:12px;border:1.5px solid var(--line-strong);display:grid;place-items:center;position:relative;transition:.15s}
.icon-btn:hover{background:var(--ink);color:var(--volt);border-color:var(--ink)}
.cart-count{position:absolute;top:-6px;right:-6px;background:var(--coral);color:#fff;font-size:10px;font-weight:700;width:18px;height:18px;border-radius:50%;display:grid;place-items:center;font-family:var(--mono)}

/* hero */
.hero{background:var(--ink);color:var(--paper);position:relative;overflow:hidden}
.hero-inner{max-width:1180px;margin:0 auto;padding:54px 24px 46px;position:relative;z-index:2}
.hero .eyebrow{color:var(--volt);margin-bottom:18px}
.hero h1{font-size:clamp(38px,7vw,80px);font-weight:800;letter-spacing:-.04em;max-width:14ch}
.hero h1 .out{color:transparent;-webkit-text-stroke:1.4px var(--paper)}
.hero p{max-width:46ch;color:#C9C4B5;margin:18px 0 0;font-size:16px}
.hero-glow{position:absolute;right:-120px;top:-120px;width:480px;height:480px;border-radius:50%;
  background:radial-gradient(circle,rgba(204,240,0,.22),transparent 62%);filter:blur(8px);z-index:1}
.hero-shoe{position:absolute;right:5%;bottom:-30px;width:320px;opacity:.9;transform:rotate(-12deg);z-index:1;filter:drop-shadow(0 30px 40px #0008)}
.hero-shoe img{width:100%;height:auto;display:block}

/* ticker */
.ticker{background:var(--volt);color:var(--ink);overflow:hidden;border-bottom:1px solid var(--ink)}
.ticker .track{display:flex;gap:40px;white-space:nowrap;animation:jk-scroll 26s linear infinite;padding:11px 0}
.ticker span{font-family:var(--mono);font-weight:700;font-size:13px;letter-spacing:.05em;display:inline-flex;align-items:center;gap:40px}
@keyframes jk-scroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* catalog */
.catalog{max-width:1180px;margin:0 auto;padding:44px 24px}
.cat-head{display:flex;align-items:flex-end;justify-content:space-between;gap:20px;flex-wrap:wrap;margin-bottom:24px}
.cat-head h2{font-size:clamp(28px,4vw,40px);font-weight:800}
.cat-head .sub{color:var(--muted);font-size:14px;margin-top:6px}
.filters{display:flex;gap:14px;flex-wrap:wrap;align-items:center;margin-bottom:26px}
.chips{display:flex;gap:8px;flex-wrap:wrap}
.chip{padding:9px 16px;border-radius:999px;border:1.5px solid var(--line-strong);font-size:13px;font-weight:600;transition:.15s;background:transparent;display:inline-block}
.chip:hover{border-color:var(--ink)}
.chip.active{background:var(--ink);color:var(--paper);border-color:var(--ink)}
.search-wrap{margin-left:auto;position:relative;flex:0 1 280px;min-width:200px}
.search-wrap input{width:100%;padding:11px 14px 11px 38px;border-radius:12px;border:1.5px solid var(--line-strong);background:#FBF9F3}
.search-wrap input:focus{outline:none;border-color:var(--ink)}
.search-wrap svg{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--muted);pointer-events:none}

.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(255px,1fr));gap:20px}
.card{background:#FBF9F3;border:1px solid var(--line-strong);border-radius:var(--r);overflow:hidden;transition:transform .2s,box-shadow .2s;display:flex;flex-direction:column}
.card:hover{transform:translateY(-5px);box-shadow:var(--shadow)}
.card .ph{aspect-ratio:1/1;position:relative;display:grid;place-items:center;overflow:hidden;background:var(--paper-3)}
.card .ph img{width:100%;height:100%;object-fit:cover}
.card .ph .shoe{font-size:88px;transform:rotate(-14deg);transition:.35s;filter:drop-shadow(0 16px 18px #00000033)}
.card:hover .ph .shoe{transform:rotate(-6deg) scale(1.08)}
.stock-badge{position:absolute;top:12px;left:12px}
.card .body{padding:15px 16px 17px;display:flex;flex-direction:column;gap:4px;flex:1}
.card .brand{font-family:var(--mono);font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
.card .name{font-family:var(--disp);font-weight:700;font-size:17px;letter-spacing:-.02em}
.card .sizes{font-size:12px;color:var(--muted);margin-top:2px}
.card .foot{display:flex;align-items:center;justify-content:space-between;margin-top:auto;padding-top:12px;gap:10px}
.card .price{flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.card .foot form{flex-shrink:0;display:flex}
.card .price{font-family:var(--disp);font-weight:800;font-size:19px}
.card .add{width:38px;height:38px;border-radius:11px;background:var(--ink);color:var(--volt);display:grid;place-items:center;transition:.15s;flex-shrink:0}
.card .add:hover{background:var(--volt);color:var(--ink)}
.card.soldout{opacity:.62}
.card.soldout .add{background:var(--paper-3);color:var(--muted);cursor:not-allowed}
.card.soldout:hover{transform:none;box-shadow:none}

/* product visual palettes (fallback saat produk belum punya foto) */
.ph-sneakers,.ph-default{background:linear-gradient(135deg,#FF8A4C,#FF5A3C)}
.ph-casual{background:linear-gradient(135deg,#5B8DEF,#3056D3)}
.ph-sport{background:linear-gradient(135deg,#2DD4A7,#0FA47F)}
.ph-boots{background:linear-gradient(135deg,#8B6F4E,#5C4632)}

/* ============================================================= CART & CHECKOUT */
.page{max-width:880px;margin:0 auto;padding:44px 24px}
.page-head{margin-bottom:24px}
.page-head h2{font-size:clamp(28px,4vw,40px);font-weight:800}
.page-head .sub{color:var(--muted);font-size:14px;margin-top:6px}
.back-link{display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:700;color:var(--muted);margin-bottom:18px;transition:.15s}
.back-link:hover{color:var(--ink)}

.checkout-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:24px;align-items:start}

.li{display:flex;gap:12px;padding:14px 0;border-bottom:1px solid var(--line)}
.li:last-child{border-bottom:none}
.li .thumb{width:60px;height:60px;border-radius:12px;display:grid;place-items:center;flex-shrink:0;font-size:30px;overflow:hidden}
.li .thumb img{width:100%;height:100%;object-fit:cover}
.li .meta{flex:1;min-width:0}
.li .meta .n{font-weight:700;font-size:14px}
