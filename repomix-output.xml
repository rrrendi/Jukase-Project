            ['brand' => 'Adidas', 'name' => 'Ultraboost Light', 'category' => 'Sport', 'size_range' => '40-45', 'color' => 'Hitam', 'price' => 2799000, 'cost' => 2300000, 'stock' => 2, 'days_ago' => 14],
