  /* Kolom pertama = baris ringkasan, selalu tampil & bisa di-tap */
  .panel > table td:first-child{
    display:flex!important;align-items:center;gap:10px;
    padding:12px 14px;cursor:pointer;font-weight:700;
  }
  .panel > table td:first-child::before{content:none}

  /* Kolom sisanya tampil hanya saat baris di-expand */
  .panel > table tr.jk-expanded td{
    display:flex;justify-content:space-between;align-items:center;gap:12px;
    padding:9px 14px;border-top:1px dashed var(--line);text-align:right
  }
