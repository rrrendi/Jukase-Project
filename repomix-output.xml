  }

  /* Baris "belum ada data" (colspan) selalu tampil apa adanya */
  .panel > table td[colspan]{display:block!important;text-align:center;padding:30px 14px}
  .panel > table td[colspan]::before{content:none}

  /* Cap 220px di kolom Item cuma relevan buat tabel desktop; di kartu mobile
     ini yang bikin teks item ke-enter padahal masih ada ruang di sampingnya */
  .panel > table td.col-item{max-width:none}

  /* Ikon chevron di depan kolom pertama — bukan "+" biar tidak ketuker
