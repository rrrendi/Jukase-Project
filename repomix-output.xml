  .cfg-grid{grid-template-columns:1fr}
  .checkout-grid{grid-template-columns:1fr}
  .field-row{grid-template-columns:1fr}
  .hero-shoe{display:none}
  .topbar-title{flex:1 1 auto}
  /* margin-left:auto tetap mendorong ke kanan; tidak lagi dipaksa flex-basis:100%
     sehingga tombol hanya turun baris kalau judul memang tidak muat (mis. "Stok
     Masuk & HPP Moving Average"), bukan selalu, biar tidak mubazir ruang */

  /* Sidebar admin -> drawer geser dari kiri, dibuka lewat tombol hamburger */
  .sidebar-toggle{display:grid}
  .sidebar{
    position:fixed;top:0;left:0;height:100vh;width:270px;max-width:82vw;
    transform:translateX(-100%);
    transition:transform .25s ease;
    z-index:200;
    box-shadow:20px 0 40px #00000040;
  }
