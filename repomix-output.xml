            ['brand' => 'Nike', 'name' => 'Pegasus 41', 'category' => 'Sport', 'size_range' => '39-45', 'color' => 'Hitam', 'price' => 2099000, 'cost' => 1690000, 'stock' => 12, 'days_ago' => 26],
